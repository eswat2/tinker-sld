{
  "name": "tinker-sld",
  "version": "0.0.799",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "9.2.1",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.499",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13",
    "vite-plugin-solid": "2.11.12",
    "yoctocolors": "2.1.2"
  },
  "dependencies": {
    "between.js": "0.1.2-fix.2",
    "solid-js": "1.9.13"
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "spell": "cspell 'src/**/*.{ts,tsx,html,css,md}'",
    "cc": "prettier --check './src/**/*.{ts,tsx,html,css,pcss,md}'",
    "format": "prettier --write './src/**/*.{ts,tsx,html,css,pcss,md}'",
    "open": "open https://tinker-sld.vercel.app"
  },
  "browserslist": [
    "Chrome 74",
    "Firefox 63",
    "Safari 11",
    "Edge 17",
    "Node 10"
  ],
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
