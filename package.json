{
  "name": "tinker-sld",
  "version": "0.0.789",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "9.2.1",
    "only-allow": "1.2.2",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.491",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.11",
    "vite-plugin-solid": "2.11.12",
    "yoctocolors": "2.1.2"
  },
  "dependencies": {
    "between.js": "0.1.2-fix.2",
    "solid-js": "1.9.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "proto-tailwindcss-clrs"
    ]
  },
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "deploy-app": "cd dist; ln -s ../.vercel; vc --prod",
    "release": "pnpm bump && pnpm build && pnpm deploy-app",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "sh ./.generate",
    "start": "vite",
    "build": "pnpm twx; pnpm format; vite build",
    "serve": "vite preview",
    "spell": "cspell 'src/**/*.{ts,tsx,html,css,md}'",
    "cc": "prettier --check './src/**/*.{ts,tsx,html,css,pcss,md}'",
    "format": "prettier --write './src/**/*.{ts,tsx,html,css,pcss,md}'",
    "open": "open https://tinker-sld.vercel.app"
  },
  "browserslist": [
    "Chrome 74",
    "Firefox 63",
    "Safari 11",
    "Edge 17",
    "Node 10"
  ],
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
